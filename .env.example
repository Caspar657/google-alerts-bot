# ============================================================
#  Google Alerts Bot — Environment Variables
#  Copy this file to .env and fill in your values.
# ============================================================

# --- API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
SENDGRID_API_KEY=SG....

# --- Email ---
TO_EMAIL=you@youragency.com
FROM_EMAIL=alerts@youragency.com        # Must be verified in SendGrid

# --- Google Alerts RSS Feeds ---
# For each client:
#   1. Go to https://www.google.com/alerts
#   2. Create (or open) an alert for the client name
#   3. Click "Show options" → Deliver to → RSS feed
#   4. Click "Create Alert" then click the RSS icon to get the feed URL
#   5. Paste the URL below (looks like https://www.google.com/alerts/feeds/XXXXX/YYYYY)

RSS_BAPCOR=https://www.google.com/alerts/feeds/REPLACE_ME/REPLACE_ME
RSS_BRISBANE_AIRPORT=https://www.google.com/alerts/feeds/REPLACE_ME/REPLACE_ME
RSS_ADORE_BEAUTY=https://www.google.com/alerts/feeds/REPLACE_ME/REPLACE_ME
RSS_SPARESBOX=https://www.google.com/alerts/feeds/REPLACE_ME/REPLACE_ME
RSS_REPCO=https://www.google.com/alerts/feeds/REPLACE_ME/REPLACE_ME
